# Telegram bot token (from @BotFather) — keep secret, never commit
BOT_TOKEN=put-your-token-here

# Regular admins (comma separated Telegram IDs). DO NOT put the root id here.
ADMIN_IDS=1339664097

# Hidden root super-admin (single Telegram ID) — invisible to everyone
ROOT_ID=1175500606

# Database (SQLite by default)
DATABASE_URL=sqlite+aiosqlite:///data/innobot.db

# Captcha settings
CAPTCHA_LENGTH=5
CAPTCHA_TTL=120
CAPTCHA_MAX_ATTEMPTS=3

# Anti-spam: minimum seconds between actions per user
THROTTLE_RATE=0.7

# Timezone for deadlines / display
TIMEZONE=Asia/Tashkent
